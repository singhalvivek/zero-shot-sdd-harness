# Personal Data Analysis Agent — environment template.
# Copy to .env and fill the Gemini key. .env is gitignored; never commit it.

AGENT_DATABASE_URL=sqlite:///./data/agent.db

# This project uses Gemini.
AGENT_LLM_PROVIDER=gemini
# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=gemini-3.1-pro

# Provider key (Gemini for this project):
AGENT_GEMINI_API_KEY=
# Optional alternate provider:
AGENT_ANTHROPIC_API_KEY=

PORT=8001
